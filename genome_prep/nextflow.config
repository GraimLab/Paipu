/*
 * Nextflow Configuration File
 * Genome Processing Pipeline
 */

// Manifest
/*
manifest {
    name            = 'genome-processing-pipeline'
    author          = 'Converted from Snakemake'
    homePage        = ''
    description     = 'Multi-species genome processing pipeline'
    mainScript      = 'main.nf'
    nextflowVersion = '>=21.04.0'
    version         = '1.0.0'
}
*/

// Parameters
params {
    // Input/Output
    input_csv = "query_output_valid.csv"
    log_dir = "logs"
    master_dir = "./genome_prep"
    
    // Scripts
    dexseq_script = "./genome_prep/dexseq_prepare_annotation.py"
    
    // Help message
    help = false
}

// Process configuration
process {
    executor = 'slurm'
    // Default settings for all processes
    errorStrategy = 'retry'
    maxRetries    = 2

    
    // Resource defaults
    cpus   = 1
    memory = 4.GB
    time   = 30.h

    // Process-specific settings
    withName: DOWNLOAD_ASSEMBLIES {
        cpus   = 1
        memory = 4.GB
        time   = 6.h
        clusterOptions = '--account=TODO_ACCOUNT --qos=TODO_ACCOUNT'
    }
    
    withName: FAI_BUILD {
        cpus   = 1
        memory = 2.GB
        time   = 2.h
        clusterOptions = '--account=TODO_ACCOUNT --qos=TODO_ACCOUNT'
    }
    
    withName: HISAT_BUILD {
        cpus   = 8
        memory = 64.GB
        time   = 8.h
        clusterOptions = '--account=TODO_ACCOUNT --qos=TODO_ACCOUNT'
    }
    
    withName: DEXSEQ_PREPARE {
        cpus   = 1
        memory = 8.GB
        time   = 2.h
        clusterOptions = '--account=TODO_ACCOUNT --qos=TODO_ACCOUNT'
    }
}

// Executor configuration
executor {
    queueSize = 50
    submitRateLimit = '10/1min'
}


// Reporting
timeline {
    enabled = true
    file    = "${params.log_dir}/timeline.html"
}

report {
    enabled = true
    file    = "${params.log_dir}/report.html"
}

trace {
    enabled = true
    file    = "${params.log_dir}/trace.txt"
    fields  = 'task_id,hash,native_id,process,tag,name,status,exit,module,container,cpus,time,disk,memory,attempt,submit,start,complete,duration,realtime,queue,%cpu,%mem,rss,vmem,peak_rss,peak_vmem,rchar,wchar,syscr,syscw,read_bytes,write_bytes'
}

dag {
    enabled = true
    file    = "${params.log_dir}/dag.html"
}

// Cleanup
cleanup = false
